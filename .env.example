NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server only. Never expose this key in NEXT_PUBLIC_* vars or client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Add this URL and the production URL to the Supabase Auth redirect allow list.
# Password recovery uses: {NEXT_PUBLIC_SITE_URL}/auth/confirm?next=/reset-password
